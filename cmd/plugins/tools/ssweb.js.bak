/**
 * @module plugins/tools/ssweb
 * @description Screenshot website using HarzRestAPI
 */

import axios from 'axios'

let handler = async (m, { conn, text, usedPrefix, command }) => {
    const tiny = (t) => t.toLowerCase().split('').map(c=>{
        const m={'a':'ᴀ','b':'ʙ','c':'ᴄ','d':'ᴅ','e':'ᴇ','f':'ꜰ','g':'ɢ','h':'ʜ','i':'ɪ','j':'ᴊ','k':'ᴋ','l':'ʟ','m':'ᴍ','n':'ɴ','o':'ᴏ','p':'ᴘ','q':'ǫ','r':'ʀ','s':'s','t':'ᴛ','u':'ᴜ','v':'ᴠ','w':'ᴡ','x':'x','y':'ʏ','z':'ᴢ'};
        return m[c]||c
    }).join('')

    const frames = ['iphone', 'desktop', 'macbook']
    let args = text?.split(/\s+/) || []
    let frame = 'desktop'
    let url = ''

    if (args.length > 0) {
        if (frames.includes(args[0].toLowerCase())) {
            frame = args[0].toLowerCase()
            url = args.slice(1).join(' ').trim()
        } else {
            url = args.join(' ').trim()
        }
    }

    if (!url) return m.reply(`╭───「 *${tiny('SCREENSHOT WEB')}* 」───\n│\n│ 📸 Ambil tangkapan layar website.\n│ 🎮 Format: ${usedPrefix + command} <frame> <url>\n│ 💡 Contoh: ${usedPrefix + command} iphone https://google.com\n│ 🌟 Pilihan Frame: ${frames.join(', ')}\n│\n╰────────────────────`)

    if (!url.startsWith('http')) url = 'https://' + url

    await conn.sendMessage(m.chat, { react: { text: '📸', key: m.key } })

    try {
        const ssUrl = `https://api.harzrestapi.web.id/api/screenshot?url=${encodeURIComponent(url)}&frame=${frame}`
        
        await conn.sendMessage(m.chat, { 
            image: { url: ssUrl }, 
            caption: `📸 *${tiny('SCREENSHOT RESULT')}*\n\n🌐 URL: ${url}\n📱 Frame: ${frame.charAt(0).toUpperCase() + frame.slice(1)}`
        }, { quoted: m })

    } catch (e) {
        console.error('SSWeb Error:', e)
        m.reply("❌ Gagal mengambil screenshot. Pastikan URL valid.")
    }
}

handler.help = ['ssweb <url>']
handler.tags = ['tools']
handler.command = ['ssweb', 'ss', 'screenshot']
handler.prefix = true

export default handler
